{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "enabledManagers": ["ansible-galaxy", "github-actions", "pep621", "pre-commit", "custom.regex"],
  "ignorePaths": [".test/**"],
  "labels": ["dependencies"],
  "semanticCommits": "enabled",
  "semanticCommitType": "deps",
  "semanticCommitScope": null,
  "lockFileMaintenance": {
    "enabled": true
  },
  "ansible-galaxy": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  },
  "pre-commit": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update the SUPERLINTER_IMAGE_TAG variable in Taskfile.yml.",
      "managerFilePatterns": ["/^Taskfile\\.yml$/"],
      "matchStrings": ["SUPERLINTER_IMAGE_TAG: \"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      "depNameTemplate": "ghcr.io/super-linter/super-linter",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "addLabels": ["ci"]
    },
    {
      "matchManagers": ["pre-commit"],
      "groupName": "pre-commit hooks"
    },
    {
      "matchManagers": ["ansible-galaxy"],
      "groupName": "ansible collections",
      "addLabels": ["ansible"]
    },
    {
      "matchManagers": ["pep621"],
      "groupName": "python toolchain"
    },
    {
      "matchDepNames": ["ghcr.io/super-linter/super-linter", "super-linter/super-linter"],
      "groupName": "super-linter",
      "addLabels": ["ci"]
    }
  ]
}
