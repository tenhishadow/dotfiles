# general config
## man sshd_config
Host *
  CheckHostIP            no
  Compression            yes
  ForwardAgent           yes
  ForwardX11             no
  HashKnownHosts         no
  PasswordAuthentication no
  ServerAliveInterval    30
  ServerAliveCountMax    3
  StrictHostKeyChecking  no
  TCPKeepAlive           yes
  UserKnownHostsFile     /dev/null

# include custom configs
Include config.d/*
Include conf.d/*
