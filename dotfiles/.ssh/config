# general config
## man sshd_config
Host *
  CheckHostIP            no
  Compression            no
  ForwardAgent           no
  ForwardX11             no
  HashKnownHosts         yes
  PasswordAuthentication no
  ServerAliveInterval    30
  ServerAliveCountMax    3
  StrictHostKeyChecking  accept-new
  TCPKeepAlive           yes


# include custom configs
Include config.d/*
Include conf.d/*
